<div style="background-color: white;">
	<%= originalEmail ? 'Original target email address is: ' + originalEmail + '' : '' %>
  </div>
<body
	style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;-webkit-font-smoothing: antialiased;-webkit-text-size-adjust: none;height: 100%;line-height: 1.6;background-color: #f6f6f6;width: 80% !important;">
	<table class="body-wrap" align="center"
		style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;background-color: #f6f6f6;width: 100%;">
		<tbody
			style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
			<tr
				style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
				<td align="center" class="container content" width="600"
					style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;vertical-align: top;max-width: 600px !important;margin: 0 auto !important;display: block !important;padding: 20px;clear: both !important;">
					<table class="main" width="100%" cellpadding="0" cellspacing="0" align="center"
						style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;background: #fff;border: 1px solid #e9e9e9;border-radius: 3px;">
						<tbody
							style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
							<tr
								style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
								<td align="center" class="logo-section"
									style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 13px !important;vertical-align: top;color: #2f68b4;font-weight: 900;padding: 20px;text-align: center;border-radius: 3px 3px 0 0;line-height: 27px;">
									<img src="<%=websiteUrl%>/assets/images/logo.png" height="65" class="logo-upsv"
										alt="Delivery APP"
										style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;max-width: 100%;margin-left: auto;margin-right: auto;display: block;">
								</td>
							</tr>
							<tr
								style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
								<td
									style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
									<div
										style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;margin: 0 auto;padding: 5px 15px">
										<% if (text) { %>
											<p><%= text %></p><br/>
										<% } %>
										<%- include(path, {data: data}); %>
									</div>
								</td>
							</tr>
							<tr bgcolor="#eee"
								style="background: #eee;font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;">
								<td bgcolor="#eee" align="center" class="footer"
									style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px !important;vertical-align: top;color: #96969f;font-weight: 900;padding: 20px;text-align: center;border-radius: 3px 3px 0 0;background: #eee;border-top: 1px solid;border-color: #d8dde4;">
									<a target="_blank" href="<%=websiteUrl%>"
										style="font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 14px;color: #348eda;text-decoration: underline;background: #eee;"><%=websiteUrl%></a>
									<div class="copyrit"
										style="background: #eee;font-family: &quot;Helvetica Neue&quot;, &quot;Helvetica&quot;, Helvetica, Arial, sans-serif;box-sizing: border-box;font-size: 12px;line-height: 2em;text-align: center;">
										Copyright <%=year%> Delivery APP
									</div>
								</td>
							</tr>
						</tbody>
					</table>
				</td>
			</tr>
		</tbody>
	</table>
</body>